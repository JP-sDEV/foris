# Fastfile for Foris iOS App
# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools

default_platform(:ios)

platform :ios do
  
  # Configuration
  app_identifier = "com.yourcompany.foris"
  scheme_name = "foris"
  workspace_name = "foris.xcworkspace"
  project_name = "foris.xcodeproj"
  
  # Before all lanes
  before_all do
    setup_circle_ci if ENV['CI']
    ensure_git_status_clean unless ENV['CI']
  end
  
  # Development lane
  desc "Build and run tests for development"
  lane :dev do
    run_tests
    build_app(
      scheme: scheme_name,
      configuration: "Debug",
      destination: "platform=iOS Simulator,name=iPhone 16"
    )
  end
  
  # Testing lane
  desc "Run all tests"
  lane :test do
    run_tests(
      scheme: scheme_name,
      device: "iPhone 16",
      code_coverage: true
    )
  end
  
  # Beta lane for TestFlight
  desc "Build and upload to TestFlight"
  lane :beta do
    # Increment build number
    increment_build_number(xcodeproj: project_name)
    
    # Build the app
    build_app(
      scheme: scheme_name,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          app_identifier => "Foris Distribution Profile"
        }
      }
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Bug fixes and improvements"
    )
    
    # Notify team
    slack(
      message: "New beta build uploaded to TestFlight! 🚀",
      channel: "#ios-releases"
    ) if ENV['SLACK_URL']
  end
  
  # Release lane for App Store
  desc "Build and upload to App Store"
  lane :release do
    # Ensure we're on main branch
    ensure_git_branch(branch: 'main')
    
    # Run tests first
    run_tests
    
    # Increment version number
    increment_version_number(xcodeproj: project_name)
    increment_build_number(xcodeproj: project_name)
    
    # Build the app
    build_app(
      scheme: scheme_name,
      configuration: "Release",
      export_method: "app-store"
    )
    
    # Upload to App Store
    upload_to_app_store(
      force: true,
      reject_if_possible: true,
      skip_metadata: false,
      skip_screenshots: false,
      submit_for_review: false
    )
    
    # Create git tag
    add_git_tag(
      tag: "v#{get_version_number(xcodeproj: project_name)}"
    )
    
    # Push to git
    push_to_git_remote
    
    # Notify team
    slack(
      message: "New release uploaded to App Store! 🎉",
      channel: "#ios-releases"
    ) if ENV['SLACK_URL']
  end
  
  # Screenshots lane
  desc "Generate screenshots for App Store"
  lane :screenshots do
    capture_screenshots(
      scheme: scheme_name,
      devices: [
        "iPhone 16 Pro Max",
        "iPhone 16",
        "iPhone SE (3rd generation)",
        "iPad Pro (12.9-inch) (6th generation)",
        "iPad Pro (11-inch) (4th generation)"
      ]
    )
    
    frame_screenshots(
      white: true,
      path: "./fastlane/screenshots"
    )
  end
  
  # Code signing lane
  desc "Setup code signing"
  lane :certificates do
    match(
      type: "development",
      app_identifier: app_identifier
    )
    
    match(
      type: "appstore",
      app_identifier: app_identifier
    )
  end
  
  # Refresh provisioning profiles
  desc "Refresh provisioning profiles"
  lane :refresh_profiles do
    match(
      type: "development",
      app_identifier: app_identifier,
      force_for_new_devices: true
    )
    
    match(
      type: "appstore",
      app_identifier: app_identifier,
      force_for_new_devices: true
    )
  end
  
  # Clean lane
  desc "Clean build artifacts"
  lane :clean do
    clear_derived_data
    clean_build_artifacts
  end
  
  # Lint lane
  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      config_file: ".swiftlint.yml",
      strict: true
    )
  end
  
  # Format lane
  desc "Format code with SwiftFormat"
  lane :format do
    sh("swiftformat ../foris --config ../.swiftformat")
  end
  
  # Dependencies lane
  desc "Update dependencies"
  lane :update_deps do
    # Update CocoaPods
    cocoapods(
      repo_update: true,
      clean_install: true
    ) if File.exist?("../Podfile")
    
    # Update Swift Package Manager dependencies
    sh("cd .. && xcodebuild -resolvePackageDependencies")
  end
  
  # Archive lane
  desc "Create archive without uploading"
  lane :archive do
    build_app(
      scheme: scheme_name,
      configuration: "Release",
      export_method: "app-store",
      skip_package_ipa: true
    )
  end
  
  # Validate lane
  desc "Validate app before submission"
  lane :validate do
    build_app(
      scheme: scheme_name,
      configuration: "Release",
      export_method: "app-store",
      skip_package_ipa: true
    )
    
    # Additional validation steps
    run_tests
    lint
  end
  
  # Error handling
  error do |lane, exception|
    slack(
      message: "❌ Lane #{lane} failed: #{exception.message}",
      channel: "#ios-releases",
      success: false
    ) if ENV['SLACK_URL']
  end
  
  # After all lanes
  after_all do |lane|
    # Clean up
    clean_build_artifacts
    
    # Success notification
    slack(
      message: "✅ Lane #{lane} completed successfully!",
      channel: "#ios-releases"
    ) if ENV['SLACK_URL'] && lane != :test
  end
  
end