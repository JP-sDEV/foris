<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Distribution method: app-store, ad-hoc, enterprise, development -->
    <key>method</key>
    <string>app-store</string>
    
    <!-- Team ID from Apple Developer Account -->
    <key>teamID</key>
    <string>YOUR_TEAM_ID</string>
    
    <!-- Upload symbols for crash reporting -->
    <key>uploadSymbols</key>
    <true/>
    
    <!-- Upload bitcode (deprecated in iOS 16) -->
    <key>uploadBitcode</key>
    <false/>
    
    <!-- Compile bitcode (deprecated in iOS 16) -->
    <key>compileBitcode</key>
    <false/>
    
    <!-- Strip Swift symbols -->
    <key>stripSwiftSymbols</key>
    <true/>
    
    <!-- Thinning for App Store distribution -->
    <key>thinning</key>
    <string>&lt;thin-for-all-variants&gt;</string>
    
    <!-- Provisioning profiles (automatic or manual) -->
    <key>provisioningProfiles</key>
    <dict>
        <key>com.yourcompany.foris</key>
        <string>YOUR_PROVISIONING_PROFILE_NAME</string>
    </dict>
    
    <!-- Signing certificate -->
    <key>signingCertificate</key>
    <string>Apple Distribution</string>
    
    <!-- Signing style: automatic or manual -->
    <key>signingStyle</key>
    <string>automatic</string>
    
    <!-- Destination for export -->
    <key>destination</key>
    <string>upload</string>
    
    <!-- Generate app size report -->
    <key>generateAppStoreInformation</key>
    <true/>
</dict>
</plist>