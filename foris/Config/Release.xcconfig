// Release.xcconfig
// Configuration settings for Release builds

// Swift compilation conditions
SWIFT_ACTIVE_COMPILATION_CONDITIONS = RELEASE

// Preprocessor definitions
GCC_PREPROCESSOR_DEFINITIONS = RELEASE=1

// API Configuration
GRAPHQL_ENDPOINT = https://api.foris.app/graphql
API_BASE_URL = https://api.foris.app

// Build settings
ENABLE_TESTABILITY = NO
SWIFT_OPTIMIZATION_LEVEL = -O
SWIFT_COMPILATION_MODE = wholemodule
GCC_OPTIMIZATION_LEVEL = s

// Debug information
DEBUG_INFORMATION_FORMAT = dwarf-with-dsym
COPY_PHASE_STRIP = YES
STRIP_INSTALLED_PRODUCT = YES
STRIP_SWIFT_SYMBOLS = YES

// Dead code stripping
DEAD_CODE_STRIPPING = YES

// Warnings
GCC_WARN_UNINITIALIZED_AUTOS = YES_AGGRESSIVE
CLANG_WARN_DOCUMENTATION_COMMENTS = YES
CLANG_WARN_SUSPICIOUS_MOVES = YES

// Code signing (distribution)
CODE_SIGN_STYLE = Manual
DEVELOPMENT_TEAM = YOUR_TEAM_ID
PROVISIONING_PROFILE_SPECIFIER = YOUR_DISTRIBUTION_PROFILE

// Bundle identifier
PRODUCT_BUNDLE_IDENTIFIER = com.yourcompany.foris

// Security
VALIDATE_PRODUCT = YES
ENABLE_STRICT_OBJC_MSGSEND = YES

// App Transport Security (production)
ENABLE_LOCAL_NETWORKING = NO