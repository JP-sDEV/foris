// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  bio       String? // Optional user bio
  avatarUrl String? // Optional avatar/profile image URL
  createdAt DateTime @default(now())

  oauthAccounts         OAuthAccount[]
  sessions              Session[]
  followers             UserFollow[]            @relation("Followers")
  following             UserFollow[]            @relation("Following")
  comments              Comment[]
  posts                 Post[]
  media                 Media[]
  leagues               League[]
  challenges            Challenge[]
  userChallenges        UserChallenge[]
  likes                 Like[]
  LeagueUser            LeagueUser[]
  UserChallengeProgress UserChallengeProgress[]
  UserChallengeLike     UserChallengeLike[]
  UserChallengeComment  UserChallengeComment[]
}

model OAuthAccount {
  id             String    @id @default(uuid()) @db.Uuid
  provider       String // e.g., "google", "apple"
  providerUserId String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFollow {
  followId    String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followId, followingId]) // Composite primary key to prevent duplicates
}

model Like {
  userId String @db.Uuid
  postId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
}

model Post {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  content     String?
  challengeId String?    @db.Uuid
  createdAt   DateTime   @default(now())
  authorId    String     @db.Uuid
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  challenge   Challenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  mediaFiles Media[]

  comments Comment[]
  likes    Like[]
}

model Media {
  id         String   @id @default(uuid()) @db.Uuid
  postId     String   @db.Uuid
  uploaderId String   @db.Uuid
  fileType   String
  url        String
  createdAt  DateTime @default(now())

  uploader User @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model League {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())
  createdBy   String   @db.Uuid

  creator          User              @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  leagueChallenges LeagueChallenge[]
  LeagueUser       LeagueUser[]
  UserChallenge    UserChallenge[]
}

model Challenge {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdAt   DateTime          @default(now())
  createdBy   String            @db.Uuid
  approved    Boolean           @default(true)
  endDate     DateTime?
  isPublic    Boolean           @default(true)
  points      Int               @default(0)
  category    ChallengeCategory @default(PERSONAL)

  creator               User                    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  userChallenges        UserChallenge[]
  leagueChallenges      LeagueChallenge[]
  UserChallengeProgress UserChallengeProgress[]
  Post                  Post[]
}

enum ChallengeCategory {
  PERSONAL
  FITNESS
  FINANCIAL
  CAREER
  EDUCATION
  SOCIAL
  HEALTH
  HOBBY
  TRAVEL
  OTHER
}

model UserChallenge {
  id          String                   @id @default(uuid()) @db.Uuid
  userId      String                   @db.Uuid
  challengeId String                   @db.Uuid
  leagueId    String?                  @db.Uuid
  completedAt DateTime?
  status      ChallengeStatus          @default(IN_PROGRESS)
  startedAt   DateTime                 @default(now())
  source      ChallengeSource          @default(PUBLIC)
  difficulty  EnumChallengeDifficulty?
  points      Int?                     @default(0)

  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge            Challenge              @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  league               League?                @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  UserChallengeLike    UserChallengeLike[]
  UserChallengeComment UserChallengeComment[]

  @@unique([userId, challengeId, source, leagueId])
}

enum EnumChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ChallengeSource {
  PUBLIC // user opted in themselves
  LEAGUE // assigned through a league
}

model UserChallengeProgress {
  userId      String          @db.Uuid
  challengeId String          @db.Uuid
  completedAt DateTime?
  status      ChallengeStatus @default(IN_PROGRESS)
  startedAt   DateTime        @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId])
}

model LeagueChallenge {
  leagueId    String @db.Uuid
  challengeId String @db.Uuid

  league    League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([leagueId, challengeId])
}

enum ChallengeStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  NOT_IN_PROGRESS
}

model LeagueUser {
  leagueId String     @db.Uuid
  userId   String     @db.Uuid
  joinedAt DateTime   @default(now())
  role     LeagueRole @default(MEMBER)

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([leagueId, userId])
}

enum LeagueRole {
  MEMBER
  ADMIN
}

model UserChallengeLike {
  userId          String   @db.Uuid
  userChallengeId String   @db.Uuid
  likedAt         DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userChallenge UserChallenge @relation(fields: [userChallengeId], references: [id], onDelete: Cascade)

  @@id([userId, userChallengeId])
  @@index([userId])
  @@index([userChallengeId])
}

model UserChallengeComment {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  userChallengeId String   @db.Uuid
  content         String
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userChallenge UserChallenge @relation(fields: [userChallengeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userChallengeId])
}
